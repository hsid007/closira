# Application
APP_NAME=Closira API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./closira.db

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006","http://localhost:8081","exp://localhost:19000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Background Tasks
ENQUIRY_PROCESSING_DELAY_SECONDS=2
